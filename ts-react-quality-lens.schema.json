{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/pmfleming/ts-react-quality-lens/ts-react-quality-lens.schema.json",
  "title": "ts-react-quality-lens artifact",
  "type": "object",
  "required": ["schema_version", "task_id", "project", "provenance", "confidence", "summary"],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "task_id": {
      "type": "string",
      "enum": [
        "audit",
        "context.project",
        "quality.hotspots",
        "quality.clones",
        "quality.escape_hatches",
        "quality.type_health",
        "quality.locality_dynamic",
        "quality.locality_leverage",
        "quality.react_health",
        "quality.dependency_health",
        "quality.cleanup",
        "correctness.catalog",
        "correctness.all",
        "map.architecture"
      ]
    },
    "project": {
      "type": "object",
      "required": ["name", "root"],
      "properties": {
        "name": { "type": "string" },
        "root": { "type": "string" },
        "framework": { "type": "string" },
        "package_manager": { "type": "string" },
        "test_runner": { "type": "string" }
      },
      "additionalProperties": true
    },
    "provenance": {
      "type": "object",
      "required": ["lens", "schema_version", "command", "host", "measured_at", "source_type"],
      "properties": {
        "lens": { "const": "ts-react-quality-lens" },
        "schema_version": { "type": "string" },
        "command": { "type": "string" },
        "host": { "type": "string" },
        "measured_at": { "type": "string" },
        "source_type": { "type": "string" }
      },
      "additionalProperties": true
    },
    "confidence": {
      "type": "object",
      "additionalProperties": {
        "type": ["boolean", "string", "number", "null"]
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": true
    },
    "records": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "findings": {
      "type": "array",
      "items": {
        "allOf": [
          { "$ref": "#/$defs/finding" },
          {
            "type": "object",
            "required": ["task_id", "introduced"],
            "properties": {
              "task_id": { "type": "string" },
              "introduced": { "type": "boolean" }
            }
          }
        ]
      }
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string" },
        "file": { "type": "string" },
        "files": { "type": "array", "items": { "type": "string" } },
        "line": { "type": ["number", "null"] },
        "score": { "type": "number" },
        "risk": { "type": "string" },
        "severity": { "type": "string" },
        "suppressed": { "type": "boolean" },
        "suppression_reason": { "type": "string" },
        "signals": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind"],
            "properties": {
              "kind": { "type": "string" },
              "value": { "type": ["string", "number", "boolean", "null"] },
              "line": { "type": ["number", "null"] },
              "specifier": { "type": "string" },
              "message": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "actions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "auto_fixable", "description"],
            "properties": {
              "type": {
                "enum": ["fix", "suppress-line", "suppress-file", "add-to-config"]
              },
              "auto_fixable": { "type": "boolean" },
              "description": { "type": "string" },
              "fix": { "type": "string" },
              "comment": { "type": "string" },
              "config_key": { "type": "string" },
              "value": true,
              "note": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
