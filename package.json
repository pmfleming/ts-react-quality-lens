{
  "name": "ts-react-quality-lens",
  "version": "0.1.0",
  "description": "Reusable TypeScript and React quality measurement artifacts for project-management-board.",
  "type": "module",
  "bin": {
    "ts-react-quality-lens": "./bin/ts-react-quality-lens.mjs"
  },
  "scripts": {
    "test": "node --test test/cli.test.mjs",
    "catalog": "node ./bin/ts-react-quality-lens.mjs catalog --config ./examples/basic/ts-react-quality-lens.config.json",
    "measure": "node ./bin/ts-react-quality-lens.mjs measure all --config ./examples/basic/ts-react-quality-lens.config.json"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    "ts-react-quality-lens.schema.json"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@typescript-eslint/parser": "^8.60.0",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jscpd": "^4.2.4",
    "typescript": "^6.0.3"
  }
}
