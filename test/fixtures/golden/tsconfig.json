{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@lib/*": ["src/lib/*"],
      "@server/*": ["src/server/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
